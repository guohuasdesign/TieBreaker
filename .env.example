# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional. Used for decision visual image generation.
# Create one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-2"
OPENAI_IMAGE_SIZE="1536x1024"
OPENAI_IMAGE_QUALITY="medium"

# DASHSCOPE_API_KEY: Optional. Used for Alibaba Cloud DashScope image generation.
# Create this in Alibaba Cloud Model Studio / DashScope.
DASHSCOPE_API_KEY="MY_DASHSCOPE_API_KEY"

# Optional DashScope image model and output size.
# Leave blank to try built-in candidates, or provide comma-separated model names.
# Example: DASHSCOPE_IMAGE_MODEL="wan2.2-t2i-flash,wanx-v1"
DASHSCOPE_IMAGE_MODEL=""
DASHSCOPE_IMAGE_SIZE="1280*720"

# Optional. China endpoint: https://dashscope.aliyuncs.com
# International endpoint often uses: https://dashscope-intl.aliyuncs.com
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com"

# Optional. Alibaba Cloud Model Studio OpenAI-compatible endpoint.
# Example Germany Frankfurt:
# ALIBABA_COMPATIBLE_BASE_URL="https://YOUR_WORKSPACE_ID.eu-central-1.maas.aliyuncs.com/compatible-mode/v1"
# ALIBABA_API_KEY can be omitted if DASHSCOPE_API_KEY is the same credential.
ALIBABA_COMPATIBLE_BASE_URL=""
ALIBABA_API_KEY=""
ALIBABA_IMAGE_MODEL="qwen-image"
ALIBABA_IMAGE_SIZE="1536x1024"

# Optional. Alibaba Cloud Model Studio native video generation endpoint.
# If you already have the full endpoint from Alibaba Cloud, paste it here.
# Example Germany Frankfurt:
# ALIBABA_VIDEO_ENDPOINT="https://YOUR_WORKSPACE_ID.eu-central-1.maas.aliyuncs.com/api/v1/services/aigc/video-generation/video-synthesis"
# Or set only the workspace host and the server will append the video path.
# ALIBABA_VIDEO_BASE_URL="https://YOUR_WORKSPACE_ID.eu-central-1.maas.aliyuncs.com"
ALIBABA_VIDEO_ENDPOINT=""
ALIBABA_VIDEO_BASE_URL=""
ALIBABA_VIDEO_MODEL="happyhorse-1.0-t2v"
ALIBABA_VIDEO_RESOLUTION="720P"
ALIBABA_VIDEO_RATIO="16:9"
ALIBABA_VIDEO_DURATION="5"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
